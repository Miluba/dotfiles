{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",
      "git branch": "allow",
      "ls": "allow",
      "cat": "allow",
      "grep": "allow",
      "glob": "allow",
      "head": "allow",
      "tail": "allow"
    },
    "edit": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "websearch": "allow",
    "webfetch": "allow"
  },
  "lsp": {
    "gopls": {
      "command": [
        "gopls"
      ],
      "extensions": [
        ".go"
      ]
    },
    "typescript-language-server": {
      "command": [
        "bunx",
        "--bun",
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".cjs",
        ".mjs",
        ".ts",
        ".tsx"
      ]
    }
  }
}
