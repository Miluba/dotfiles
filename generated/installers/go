#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(unset CDPATH; cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(unset CDPATH; cd "${SCRIPT_DIR}/.." && pwd)"
# shellcheck source=generated/lib/common
source "${ROOT_DIR}/lib/common"
# shellcheck source=generated/lib/spec
source "${ROOT_DIR}/lib/spec"
# shellcheck source=generated/lib/platform
source "${ROOT_DIR}/lib/platform"
# shellcheck source=generated/lib/install
source "${ROOT_DIR}/lib/install"
DRY_RUN=0
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=1
install_from_spec go "$DRY_RUN"
